  "key": "A# minor",
  "genre": [
    "Alternative",
    "Indie"
  ],
  "difficultyLevel": 7,
  "lyrics": "Up ahead, oh, up ahead of us In the distance I see Just a little bit of crossroads It might take us all night To feel the right way to go And I grow old It might take us all our lives To take that first step towards our destiny The best of me, all the things I want Inside my dreams are next to me I feel it in my bones Baby, I feel it coming home My value in me that makes me step And find which way to go With these crossroads Even if it's solitude, I'm not alone At the crossroads of our team Crossroads of my life and I and our team Together, which way I'll strive, we roll And across roads, I'll be Setting up an anchor for you to find You next to me and I'll wait I'll awake and watch the crossroads Of all we used to know, feel, dream, and be nine Be careful of me, take care of you As we step into the new version of our lives This wound in these energy Make me feel so connected to you I almost don't wanna be free Cross my heart, I hope to die If I ever see another like you in my life I'll remember you At the crossroads, baby, I'm Next to you, always in your heart No need to fall apart Baby, at the crossroads You will find that you know which way to go",
  "lyricsSegments": [
    {
      "end": 23.079999923706055,
      "text": "Up ahead, oh, up ahead of us In the distance I see",
      "start": 11.0600004196167
    },
    {
      "end": 34.84000015258789,
      "text": "Just a little bit of crossroads It might take us all night",
      "start": 23.079999923706055
    },
    {
      "end": 51.939998626708984,
      "text": "To feel the right way to go And I grow old",
      "start": 34.84000015258789
    },
    {
      "end": 62.779998779296875,
      "text": "It might take us all our lives To take that first step towards our destiny",
      "start": 53.439998626708984
    },
    {
      "end": 70.68000030517578,
      "text": "The best of me, all the things I want Inside my dreams are next to me",
      "start": 62.779998779296875
    },
    {
      "end": 85.12000274658203,
      "text": "I feel it in my bones Baby, I feel it coming home",
      "start": 70.68000030517578
    },
    {
      "end": 93.4800033569336,
      "text": "My value in me that makes me step And find which way to go",
      "start": 85.19999694824219
    },
    {
      "end": 106.19999694824219,
      "text": "With these crossroads Even if it's solitude, I'm not alone",
      "start": 93.4800033569336
    },
    {
      "end": 116.83999633789062,
      "text": "At the crossroads of our team Crossroads of my life and I and our team",
      "start": 106.55999755859375
    },
    {
      "end": 133.77999877929688,
      "text": "Together, which way I'll strive, we roll And across roads, I'll be",
      "start": 116.83999633789062
    },
    {
      "end": 148.66000366210938,
      "text": "Setting up an anchor for you to find You next to me and I'll wait",
      "start": 134.77999877929688
    },
    {
      "end": 169.82000732421875,
      "text": "I'll awake and watch the crossroads Of all we used to know, feel, dream, and be nine",
      "start": 148.66000366210938
    },
    {
      "end": 183.5399932861328,
      "text": "Be careful of me, take care of you As we step into the new version of our lives",
      "start": 169.82000732421875
    },
    {
      "end": 192.94000244140625,
      "text": "This wound in these energy Make me feel so connected to you",
      "start": 183.5399932861328
    },
    {
      "end": 204.3000030517578,
      "text": "I almost don't wanna be free Cross my heart, I hope to die",
      "start": 192.94000244140625
    },
    {
      "end": 215.3000030517578,
      "text": "If I ever see another like you in my life I'll remember you",
      "start": 204.3000030517578
    },
    {
      "end": 225.4600067138672,
      "text": "At the crossroads, baby, I'm Next to you, always in your heart",
      "start": 215.97999572753906
    },
    {
      "end": 235.60000610351562,
      "text": "No need to fall apart Baby, at the crossroads",
      "start": 226.4600067138672
    },
    {
      "end": 241.97999572753906,
      "text": "You will find that you know which way to go",
      "start": 235.72000122070312
    }
  ],
  "unlock": {
    "card": "card-128",
    "fragments": 10
  }
