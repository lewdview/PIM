    },
    {
      "end": 76.66000366210938,
      "text": "Hey, people are just things we can replace",
      "start": 73.77999877929688
    },
    {
      "end": 82.08000183105469,
      "text": "People are things we can find again",
      "start": 78.04000091552734
    },
    {
      "end": 86.30000305175781,
      "text": "Unique in this world, that's my view on you, baby",
      "start": 82.08000183105469
    },
    {
      "end": 88.44000244140625,
      "text": "Unique is my idea",
      "start": 86.30000305175781
    },
    {
      "end": 93.83999633789062,
      "text": "Even if the title doesn't",
      "start": 90.19999694824219
    },
    {
      "end": 98.12000274658203,
      "text": "Say what you want, it's still there in my mind",
      "start": 93.91999816894531
    },
    {
      "end": 100.76000213623047,
      "text": "Baby, I don't want others",
