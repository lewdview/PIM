    },
    {
      "end": 162.9199981689453,
      "text": "I'll never get it back again All the scars that you did left my heart obliterated",
      "start": 150.9199981689453
    },
    {
      "end": 168.60000610351562,
      "text": "Obliterated Scars you left in my mind",
      "start": 165.36000061035156
    },
    {
      "end": 175.13999938964844,
      "text": "I will never, ever, ever get past The scars you left in my mind",
      "start": 169
    },
    {
      "end": 185.6199951171875,
      "text": "You turned my past to glass I can see you in the night, yeah",
      "start": 175.13999938964844
    },
    {
      "end": 191.33999633789062,
      "text": "The past I can see you're not alright",
