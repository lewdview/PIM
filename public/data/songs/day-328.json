    },
    {
      "end": 25.940000534057617,
      "text": "Society won't ever be me",
      "start": 20.600000381469727
    },
    {
      "end": 34.599998474121094,
      "text": "And so I climb, baby, I climb",
      "start": 25.940000534057617
    },
    {
      "end": 41.040000915527344,
      "text": "Up my destiny",
      "start": 37
    },
    {
      "end": 46.939998626708984,
      "text": "Yeah, it's all waiting on me",
      "start": 42.900001525878906
    },
    {
      "end": 51.939998626708984,
      "text": "Waiting on me to be home",
      "start": 47.52000045776367
    },
    {
      "end": 57.040000915527344,
      "text": "Waiting on me to stop the drugs",
      "start": 52.939998626708984
    },
    {
      "end": 61.31999969482422,
      "text": "Stop feeling alone",
      "start": 57.040000915527344
    },
    {
      "end": 69.94000244140625,
      "text": "I feel like you're home",
      "start": 63.65999984741211
    },
    {
      "end": 75.0199966430664,
      "text": "Oh, sometimes it don't matter",
      "start": 71.81999969482422
    },
    {
      "end": 81.04000091552734,
      "text": "Sometimes it don't matter how hard you climb",
      "start": 75.0199966430664
