    },
    {
      "end": 158.1999969482422,
      "text": "Outlast it all",
      "start": 155.82000732421875
    },
    {
      "end": 163.94000244140625,
      "text": "I'm gonna outlast me, it's my thoughts and energy",
      "start": 158.60000610351562
    },
    {
      "end": 168.74000549316406,
      "text": "As it goes spectacularly from one point to another",
      "start": 164.82000732421875
    },
    {
      "end": 174.0399932861328,
      "text": "All across universes and a time to a university",
      "start": 168.9600067138672
    },
    {
      "end": 178.1999969482422,
      "text": "In your mind, not pinnacle to me, I can't see",
