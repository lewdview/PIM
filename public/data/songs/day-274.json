    },
    {
      "end": 181.44000244140625,
      "text": "Progress, anyway",
      "start": 179.83999633789062
    },
    {
      "end": 187.0800018310547,
      "text": "Then again, are you even looking my way?",
      "start": 182.55999755859375
    },
    {
