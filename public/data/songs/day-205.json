    },
    {
      "end": 160.39999389648438,
      "text": "The truth lies within you",
      "start": 156.66000366210938
    },
    {
      "end": 162.4199981689453,
      "text": "In the night you fight",
      "start": 160.66000366210938
    },
    {
      "end": 165.27999877929688,
      "text": "Everything you thought was positive was the best",
      "start": 162.4199981689453
    },
    {
      "end": 169.6999969482422,
      "text": "But then you come back around and don't even try to",
      "start": 165.27999877929688
    },
