    },
    {
      "end": 62.36000061035156,
      "text": "The truth in your lies, lies within you",
      "start": 58.08000183105469
    },
    {
      "end": 65.77999877929688,
      "text": "Lies, the truth of all you do",
      "start": 62.36000061035156
    },
    {
      "end": 69.5,
      "text": "The truth in your lies, lies within you",
      "start": 65.77999877929688
    },
    {
      "end": 73.31999969482422,
      "text": "We have the truth of all you do",
      "start": 70.0199966430664
    },
    {
      "end": 78.26000213623047,
      "text": "Undercutting different levels, different moments that you swore on us",
      "start": 73.80000305175781
    },
    {
      "end": 86.76000213623047,
      "text": "But you lied to get out the comatic retribution coming over you",
      "start": 78.26000213623047
    },
    {
      "end": 91.37999725341797,
      "text": "So don't bow to the pressure, the hate to feel",
      "start": 86.86000061035156
    },
    {
      "end": 94.4800033569336,
      "text": "Come and relate, empathy's the deal",
      "start": 91.37999725341797
    },
    {
      "end": 97.13999938964844,
      "text": "If you stay close to you",
      "start": 94.4800033569336
    },
    {
      "end": 101.41999816894531,
      "text": "And don't lie your truth away in the night",
      "start": 97.13999938964844
    },
    {
