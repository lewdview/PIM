    },
    {
      "end": 25.719999313354492,
      "text": "Not just one little person over here, we're all the like mothafucka.",
      "start": 19.700000762939453
    },
    {
      "end": 27.559999465942383,
      "text": "Now come on.",
      "start": 26.639999389648438
    },
    {
      "end": 57.41999816894531,
      "text": "Come in.",
      "start": 57.380001068115234
    },
    {
      "end": 57.459999084472656,
      "text": "Ciao.",
      "start": 57.439998626708984
    },
    {
      "end": 57.540000915527344,
      "text": "Mothafucka, ciao.",
      "start": 57.5
    },
    {
      "end": 60.70000076293945,
      "text": "It feels good to feel good.",
      "start": 58.70000076293945
    },
    {
      "end": 65.76000213623047,
      "text": "So feel good with me, yeah.",
      "start": 64.0999984741211
    },
    {
      "end": 67.05999755859375,
      "text": "Hakuna Matata.",
      "start": 65.77999877929688
    },
    {
      "end": 70.08000183105469,
      "text": "No worries, yesterday be our guest.",
      "start": 67.73999786376953
    },
    {
      "end": 72.05999755859375,
      "text": "This is what we come to you.",
      "start": 70.30000305175781
    },
    {
      "end": 74.83999633789062,
      "text": "I just, and just, and just, and just, and just.",
      "start": 72.12000274658203
    },
    {
      "end": 76.62000274658203,
      "text": "Oh yeah.",
      "start": 75.94000244140625
    },
    {
      "end": 82.76000213623047,
      "text": "I know you wanna be happy even if you're sad.",
      "start": 77.33999633789062
    },
    {
      "end": 84.4000015258789,
      "text": "Oh baby, baby.",
      "start": 82.87999725341797
    },
    {
      "end": 86.5199966430664,
      "text": "I know you want life.",
