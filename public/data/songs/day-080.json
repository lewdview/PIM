    },
    {
      "end": 66.27999877929688,
      "text": "Pop it like a drop it, just drop with me",
      "start": 63.959999084472656
    },
    {
      "end": 68.5,
      "text": "Assault rifle",
      "start": 67.33999633789062
    },
    {
      "end": 73.19999694824219,
      "text": "Oh, niggas dropping and killing everywhere",
      "start": 70.5999984741211
    },
    {
      "end": 77.12000274658203,
      "text": "Inside of my home",
