      "start": 32.040000915527344
    },
    {
      "end": 36.65999984741211,
      "text": "Don't let the hate to break",
      "start": 34.959999084472656
    },
    {
      "end": 39.31999969482422,
      "text": "Don't break the hate to feel",
      "start": 37.36000061035156
    },
    {
      "end": 41.58000183105469,
      "text": "Hit a little vortex in my mind",
      "start": 39.31999969482422
    },
    {
      "end": 44.36000061035156,
      "text": "I got an assault rifle and what's your crime?",
      "start": 41.58000183105469
    },
    {
      "end": 47.31999969482422,
      "text": "Are we in Atlanta, are we next to the one",
      "start": 44.900001525878906
    },
    {
      "end": 49.119998931884766,
      "text": "That says that I can't get shot",
      "start": 47.31999969482422
    },
    {
      "end": 51.279998779296875,
      "text": "When you hear when the beat go down",
      "start": 49.119998931884766
    },
    {
      "end": 54.63999938964844,
      "text": "That's what they say in this town",
      "start": 52
    },
    {
