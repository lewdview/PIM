  "key": "C# minor",
  "genre": [
    "Alternative",
    "Indie"
  ],
  "difficultyLevel": 4,
  "lyrics": "What if this is all for you, what if this is all for you, from you? What if you could look at another version of you, oh what would you see, if you saw you in dimension 353, do you think you'd have the patience for you when you go past a line? Do you think you'd love you just the way you think you treat yourself inside, I said, what if this is all for you, from you? Are you from before, before, before, or after, or wherever your door leads you, pretty little violet thing, oh what if it's all for you, my dear? All the winds and all the rains and all this mess of entities, what if it's all for you, what if it's all for you, from you? All the sadness you give to others, what if that was you, what if you made you feel so small and not even validated in this? Winter when you don't know where to go, but I will tell you this, there's one thing that's for sure and that's all, it's all for you, from you.",
  "lyricsSegments": [
    {
      "end": 20.540000915527344,
      "text": "What if this is all for you, what if this is all for you, from you?",
      "start": 4.260000228881836
    },
    {
      "end": 38.91999816894531,
      "text": "What if you could look at another version of you, oh what would you see, if you saw",
      "start": 23.739999771118164
    },
    {
      "end": 54.959999084472656,
      "text": "you in dimension 353, do you think you'd have the patience for you when you go past a line?",
      "start": 38.91999816894531
    },
    {
      "end": 83.83999633789062,
      "text": "Do you think you'd love you just the way you think you treat yourself inside, I said, what if this is all for you, from you?",
      "start": 57.52000045776367
    },
    {
      "end": 106.5999984741211,
      "text": "Are you from before, before, before, or after, or wherever your door leads you, pretty little violet thing, oh what if it's all for you, my dear?",
      "start": 85.30000305175781
    },
    {
      "end": 135.8800048828125,
      "text": "All the winds and all the rains and all this mess of entities, what if it's all for you, what if it's all for you, from you?",
      "start": 106.5999984741211
    },
    {
      "end": 162.94000244140625,
      "text": "All the sadness you give to others, what if that was you, what if you made you feel so small and not even validated in this?",
      "start": 139.44000244140625
    },
    {
      "end": 185.17999267578125,
      "text": "Winter when you don't know where to go, but I will tell you this, there's one thing that's for sure and that's all, it's all for you, from you.",
      "start": 162.94000244140625
    }
  ],
  "unlock": {
    "card": "card-207",
    "fragments": 10
  }
