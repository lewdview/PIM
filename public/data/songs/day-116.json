    },
    {
      "end": 83.23999786376953,
      "text": "Get the fuck off",
      "start": 82.04000091552734
    },
    {
      "end": 84.37999725341797,
      "text": "Ayy",
      "start": 83.81999969482422
    },
    {
      "end": 86.41999816894531,
      "text": "Shoot up on him if you want to",
