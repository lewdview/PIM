    {
      "end": 1.2599999904632568,
      "text": "Yeah!",
      "start": 0.7400000095367432
    },
    {
      "end": 4,
      "text": "Did he hear it?",
      "start": 3
    },
    {
      "end": 5.760000228881836,
      "text": "Motherfucker!",
      "start": 5.239999771118164
    },
    {
      "end": 8.020000457763672,
      "text": "I think he can.",
      "start": 6.920000076293945
    },
    {
      "end": 9.180000305175781,
      "text": "Shit.",
      "start": 8.699999809265137
    },
    {
      "end": 13,
      "text": "Ayy, I come from Mckenna's and I come from L.A.",
      "start": 10.0600004196167
    },
    {
      "end": 14.260000228881836,
      "text": "And I took you on your mind",
      "start": 13.100000381469727
    },
    {
      "end": 15.539999961853027,
      "text": "And I did some damn",
      "start": 14.260000228881836
    },
    {
      "end": 18.31999969482422,
      "text": "Don't worry about it, don't judge me",
      "start": 15.84000015258789
    },
    {
      "end": 19.940000534057617,
      "text": "I'm just sittin' in your back pocket",
      "start": 18.31999969482422
    },
    {
      "end": 22.81999969482422,
      "text": "Lovely, now in a seat in your seat",
      "start": 20.100000381469727
    },
    {
      "end": 24.6200008392334,
      "text": "Sittin' there with smoke still through",
      "start": 22.920000076293945
    },
    {
      "end": 25.600000381469727,
      "text": "You can't be brave",
      "start": 24.6200008392334
    },
    {
      "end": 27.899999618530273,
      "text": "Sittin' in the back, looking at you like",
      "start": 25.719999313354492
    },
    {
      "end": 30,
      "text": "What are you doing?",
      "start": 27.899999618530273
    },
    {
      "end": 32.439998626708984,
      "text": "Get in your mind when you come with me",
      "start": 30.68000030517578
    },
    {
      "end": 35.119998931884766,
      "text": "It's just a fucking design, it's just a fucking crime",
      "start": 32.439998626708984
    },
    {
      "end": 37.2599983215332,
      "text": "Can't do nothing over the left",
      "start": 35.31999969482422
    },
    {
      "end": 38.5,
      "text": "You gotta fuck with me",
      "start": 37.2599983215332
    },
    {
      "end": 39.939998626708984,
      "text": "I gotta get your best",
      "start": 38.5
    },
    {
      "end": 44.380001068115234,
      "text": "Ayy, don't you know that you just can't beat me?",
      "start": 39.939998626708984
    },
    {
      "end": 46.31999969482422,
      "text": "I'm sorry",
      "start": 45.040000915527344
    },
    {
      "end": 47.34000015258789,
      "text": "That it",
      "start": 46.380001068115234
    },
    {
      "end": 49.02000045776367,
      "text": "Deceives you",
      "start": 47.86000061035156
    },
    {
      "end": 50.97999954223633,
      "text": "But you ain't up",
