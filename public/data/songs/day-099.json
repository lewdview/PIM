    },
    {
      "end": 44.279998779296875,
      "text": "Do to me",
      "start": 42.36000061035156
    },
    {
      "end": 46.040000915527344,
      "text": "All the things",
      "start": 44.279998779296875
    },
    {
      "end": 47.380001068115234,
      "text": "That you silly little",
      "start": 46.040000915527344
    },
    {
      "end": 50.2599983215332,
      "text": "Why'd you treat me",
      "start": 47.720001220703125
    },
    {
      "end": 51.81999969482422,
      "text": "One way",
      "start": 50.2599983215332
    },
    {
      "end": 53.900001525878906,
      "text": "Then another way",
      "start": 52.040000915527344
    },
    {
      "end": 55.119998931884766,
      "text": "Behind my back",
      "start": 53.900001525878906
    },
    {
      "end": 57.79999923706055,
      "text": "Why'd you do",
      "start": 56
    },
    {
      "end": 59.68000030517578,
      "text": "All the things",
      "start": 57.79999923706055
    },
    {
      "end": 61.560001373291016,
      "text": "You said you'd never do",
      "start": 59.68000030517578
    },
    {
      "end": 65.4800033569336,
      "text": "You said you never do",
      "start": 62.720001220703125
    },
    {
      "end": 68,
