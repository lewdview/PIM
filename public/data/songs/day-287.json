      "start": 64.54000091552734
    },
    {
      "end": 69.86000061035156,
      "text": "But you give it away",
      "start": 67.5199966430664
    },
    {
      "end": 73.04000091552734,
      "text": "If you're up all night",
      "start": 70.63999938964844
    },
    {
      "end": 76.37999725341797,
      "text": "Woah",
      "start": 75.33999633789062
    },
    {
      "end": 78.05999755859375,
      "text": "Woah",
      "start": 76.37999725341797
    },
    {
      "end": 82.04000091552734,
      "text": "I know you're going down that road again",
      "start": 78.05999755859375
    },
    {
      "end": 83.41999816894531,
      "text": "Woah",
      "start": 82.36000061035156
    },
    {
      "end": 85.83999633789062,
      "text": "No matter what I say",
      "start": 84.37999725341797
    },
    {
      "end": 88.63999938964844,
      "text": "Yeah, I know you're going down again",
      "start": 86.37999725341797
    },
    {
      "end": 91.95999908447266,
      "text": "Woah",
      "start": 90.9000015258789
    },
    {
      "end": 95.37999725341797,
      "text": "Woah",
      "start": 94.86000061035156
    },
    {
      "end": 97.18000030517578,
      "text": "Woah",
      "start": 96.12000274658203
    },
    {
      "end": 98.55999755859375,
      "text": "Don't get lost",
      "start": 97.18000030517578
    },
    {
      "end": 100.58000183105469,
      "text": "My friend, I said no",
      "start": 98.55999755859375
    },
    {
      "end": 101.91999816894531,
      "text": "Sometimes",
      "start": 101.37999725341797
    },
    {
      "end": 104.62000274658203,
      "text": "Yeah",
      "start": 103.91999816894531
    },
    {
      "end": 107.94000244140625,
      "text": "Don't look back",
      "start": 105.77999877929688
    },
    {
      "end": 110.9000015258789,
      "text": "To yesterday",
      "start": 109.5
    },
    {
      "end": 116.05999755859375,
      "text": "As I look forward",
      "start": 112.08000183105469
    },
    {
      "end": 119.87999725341797,
      "text": "All the way, yeah, all the way forward",
      "start": 116.05999755859375
    },
    {
      "end": 121.9000015258789,
      "text": "I look at myself",
      "start": 119.87999725341797
    },
    {
      "end": 124.91999816894531,
      "text": "In the mirror, see it clear in the mirror, see",
      "start": 121.9000015258789
    },
    {
      "end": 128.32000732421875,
      "text": "I ain't a checklist, oh",
      "start": 124.91999816894531
    },
    {
      "end": 131.24000549316406,
      "text": "So take that shit and run and go",
      "start": 128.32000732421875
    },
    {
