      "text": "Woah",
      "start": 141.5399932861328
    },
    {
      "end": 145.33999633789062,
      "text": "Cause you're just going down again down that road",
      "start": 142.39999389648438
    },
    {
      "end": 148,
      "text": "Woah",
      "start": 147.13999938964844
    },
    {
      "end": 151.5800018310547,
      "text": "The only road you will ever know",
      "start": 148
    },
    {
      "end": 154.27999877929688,
      "text": "Woah",
      "start": 153.4199981689453
    },
    {
      "end": 157.97999572753906,
      "text": "Are you checking off your checklist?",
      "start": 155.27999877929688
    },
    {
      "end": 163.66000366210938,
      "text": "Down that unknown road that you're on",
      "start": 160.1199951171875
    },
    {
      "end": 164.25999450683594,
      "text": "Woah",
      "start": 163.66000366210938
    },
    {
      "end": 175.60000610351562,
      "text": "Nobody's looking for you down that road",
      "start": 172.47999572753906
    },
    {
      "end": 176.94000244140625,
      "text": "Please stay, don't go",
      "start": 175.60000610351562
    },
    {
      "end": 180.44000244140625,
      "text": "Anyone can see",
      "start": 177.5800018310547
    },
    {
      "end": 183.16000366210938,
      "text": "And you",
