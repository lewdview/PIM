    },
    {
      "end": 25.780000686645508,
      "text": "Are you going down the road again?",
      "start": 22
    },
    {
      "end": 29.860000610351562,
      "text": "Woah",
      "start": 29.15999984741211
    },
    {
      "end": 33.779998779296875,
      "text": "My friend, are you going down the road again?",
      "start": 29.860000610351562
    },
    {
      "end": 38.959999084472656,
      "text": "Woah",
      "start": 38.2599983215332
    },
    {
      "end": 39.02000045776367,
      "text": "Woah",
      "start": 38.959999084472656
    },
    {
      "end": 43.79999923706055,
      "text": "I know you're going there, please be careful",
      "start": 39.31999969482422
    },
    {
      "end": 45.439998626708984,
      "text": "Woah",
      "start": 44.7400016784668
    },
    {
      "end": 50.2400016784668,
      "text": "Or you could lose your soul and the thing that makes you you",
      "start": 46.560001373291016
    },
    {
      "end": 50.68000030517578,
      "text": "My mama",
      "start": 50.2400016784668
    },
    {
      "end": 53.02000045776367,
      "text": "My mama",
      "start": 50.68000030517578
    },
    {
      "end": 55.2599983215332,
      "text": "Told me",
      "start": 53.18000030517578
    },
    {
      "end": 57.65999984741211,
      "text": "Keep your ass at home",
      "start": 55.2599983215332
    },
    {
      "end": 61.81999969482422,
      "text": "When it gets so late at night",
      "start": 58.68000030517578
    },
    {
      "end": 63.84000015258789,
      "text": "And the day",
      "start": 62.68000030517578
    },
    {
      "end": 67.13999938964844,
