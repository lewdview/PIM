    {
      "end": 76.08000183105469,
      "text": "♪ It's alright, you should just chill out, we'll be together, no matter what ♪",
      "start": 70.4800033569336
    },
    {
      "end": 81.54000091552734,
      "text": "♪ Cause you're like my love and you're all that I got, chill out, chill out, chill out, baby ♪",
      "start": 76.08000183105469
    },
    {
      "end": 87.27999877929688,
      "text": "♪ Chill out, chill out, there is no maybe, you know, chill out, baby, come on, take my hand ♪",
      "start": 81.54000091552734
    },
    {
      "end": 92.23999786376953,
      "text": "♪ Let's go find another girl to get down with, come on, it's a plan, hey, hey ♪",
      "start": 87.27999877929688
    },
    {
      "end": 104.83999633789062,
      "text": "♪ You know you're the only one I want, baby, I adore you ♪",
