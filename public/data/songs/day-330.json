    },
    {
      "end": 191.16000366210938,
      "text": "Maybe it's that",
      "start": 190.0800018310547
    },
    {
      "end": 192.47999572753906,
      "text": "I was the one that I think",
      "start": 191.16000366210938
    },
    {
      "end": 194.5399932861328,
      "text": "By looking at my life from",
      "start": 192.47999572753906
    },
    {
      "end": 196.4600067138672,
      "text": "A way through another",
      "start": 194.5399932861328
    },
    {
      "end": 199.86000061035156,
      "text": "Take one side of the glass in my arm",
      "start": 196.4600067138672
    },
    {
      "end": 202.47999572753906,
      "text": "Waiting for me",
