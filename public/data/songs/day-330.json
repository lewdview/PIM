    },
    {
      "end": 204.8000030517578,
      "text": "Still in the dark",
      "start": 203.02000427246094
    },
    {
      "end": 208.32000732421875,
      "text": "With a drug and a shot in my heart",
      "start": 204.8000030517578
    },
    {
      "end": 211.47999572753906,
      "text": "Yeah, I'm still in the motherfucking dark",
      "start": 208.5800018310547
    },
    {
      "end": 217.05999755859375,
      "text": "I don't wanna fuck it up for you or me",
      "start": 213.0399932861328
    },
    {
      "end": 220.8000030517578,
      "text": "I don't wanna fuck it up for anyone",
      "start": 217.1199951171875
    },
    {
      "end": 222.8000030517578,
      "text": "But I guess I already did it",
      "start": 220.8000030517578
    },
    {
      "end": 224.8000030517578,
      "text": "You hear that?",
      "start": 223.6199951171875
    },
    {
