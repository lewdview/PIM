    },
    {
      "end": 84.44000244140625,
      "text": "I'll be okay",
      "start": 82.30000305175781
    },
    {
      "end": 86.66000366210938,
      "text": "And the summer's end",
      "start": 84.44000244140625
    },
    {
      "end": 90.4000015258789,
      "text": "I'll know the fences and I'll",
      "start": 86.80000305175781
    },
    {
      "end": 93.86000061035156,
      "text": "Have a better sense of time",
      "start": 90.4000015258789
    },
    {
      "end": 95.27999877929688,
      "text": "For you",
      "start": 93.86000061035156
    },
    {
      "end": 99.5199966430664,
      "text": "I'll not break you down",
