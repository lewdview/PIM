  "lyricsSegments": [
    {
      "end": 22.860000610351562,
      "text": "Listen to me like I listen to you",
      "start": 18.639999389648438
    },
    {
      "end": 26.920000076293945,
      "text": "Why don't we do what we used to do and make love",
      "start": 22.860000610351562
    },
    {
      "end": 31.34000015258789,
      "text": "We don't have to fight, no not tonight",
      "start": 26.920000076293945
    },
    {
      "end": 35.81999969482422,
      "text": "I'll let you be right, you know you were always right",
      "start": 31.34000015258789
    },
    {
      "end": 39.41999816894531,
      "text": "You know the fine, the right, the wrong",
      "start": 35.81999969482422
    },
    {
      "end": 44.099998474121094,
      "text": "We're always waiting for the other wrong",
      "start": 39.41999816894531
    },
    {
      "end": 47.2599983215332,
      "text": "Shoes dropping full, spilling life",
      "start": 44.099998474121094
    },
    {
      "end": 50.279998779296875,
      "text": "Guns everywhere, love emotion",
      "start": 47.2599983215332
    },
    {
      "end": 53.91999816894531,
      "text": "Intimate possession of souls",
      "start": 50.65999984741211
    },
    {
      "end": 58.91999816894531,
      "text": "Twin flames so don't let go",
      "start": 54.91999816894531
    },
    {
      "end": 64.72000122070312,
      "text": "But fight for us, not you, not me",
      "start": 58.91999816894531
    },
    {
      "end": 70.27999877929688,
      "text": "Not single desires but family unity",
      "start": 64.72000122070312
    },
    {
      "end": 75.31999969482422,
      "text": "So listen to me and I'll listen to you",
      "start": 70.27999877929688
    },
    {
      "end": 80.69999694824219,
      "text": "Gotta start somewhere, it's up to me",
      "start": 75.31999969482422
    },
    {
      "end": 85.44000244140625,
      "text": "Me and you, it's a brighter picture",
      "start": 80.69999694824219
    },
    {
      "end": 88.69999694824219,
      "text": "We work together and",
      "start": 85.45999908447266
    },
    {
      "end": 92.58000183105469,
      "text": "Listen to me like I listen to you",
      "start": 88.91999816894531
    },
    {
      "end": 96.72000122070312,
      "text": "Why don't we do what we used to do and make love",
      "start": 92.58000183105469
    },
    {
      "end": 101.18000030517578,
      "text": "We don't have to fight, no not tonight",
      "start": 96.9000015258789
    },
    {
      "end": 105.77999877929688,
      "text": "I'll let you be right, you know you were always right",
      "start": 101.18000030517578
    },
    {
      "end": 111.13999938964844,
      "text": "And it's for certain to view",
      "start": 107.45999908447266
    },
    {
      "end": 114.9800033569336,
      "text": "That things will be what they're meant to be",
      "start": 111.13999938964844
    },
    {
      "end": 117.77999877929688,
      "text": "And it's okay with me",
      "start": 115.12000274658203
    },
    {
      "end": 123.54000091552734,
      "text": "If I don't belong, cause there ain't nothing for you but me",
      "start": 118.69999694824219
    },
    {
      "end": 127.73999786376953,
      "text": "Listen to me while I listen to you",
      "start": 123.5999984741211
    },
    {
      "end": 131.77999877929688,
      "text": "Maybe we can talk together and not be",
      "start": 127.73999786376953
    },
    {
      "end": 135.86000061035156,
      "text": "Interrupting, interjecting, always my lesson",
      "start": 131.77999877929688
    },
    {
      "end": 141.25999450683594,
      "text": "Just waiting for a place to put our own stake in",
