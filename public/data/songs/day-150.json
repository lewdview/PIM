    },
    {
      "end": 181.6199951171875,
      "text": "All I really fucking know",
      "start": 177.5399932861328
    },
    {
      "end": 190.0800018310547,
      "text": "is that I love you.",
      "start": 186.75999450683594
    },
    {
      "end": 195.22000122070312,
      "text": "I miss you.",
      "start": 192.83999633789062
    },
    {
      "end": 197.4199981689453,
      "text": "I miss you.",
