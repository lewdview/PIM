  "difficultyLevel": 2,
  "lyrics": "► When she puts a sticker on a chair shirt, he feels like a star I wish you'd land to get some upon my cheek It leaves the sky Memories surrounding, as sounds sleep, and who we are. Which host, Earth, they party, it's only a list of the fair My heart stays a bit risky I wish you wasn't there Memories roundy As soon as sleep There who we are One more day, kid, until his girl Till more years and then I'm gone ► (music) Some may question my wisdom To remain for the sake of a child But it's so subjective Remed of its own Do you explain what take a while? 'Cause February's rounding, this ain't all I'm saying There we are One more day Just 10 more years and then I'm gone Memories surrounding The sin of sleep There who we are ► ► Thank you. ►",
  "lyricsSegments": [
    {
      "end": 12,
      "text": "►",
      "start": 0
    },
    {
      "end": 23.5,
      "text": "When she puts a sticker on a chair shirt, he feels like a star",
      "start": 11.5
    },
    {
      "end": 35,
      "text": "I wish you'd land to get some upon my cheek It leaves the sky",
      "start": 23
    },
    {
      "end": 46.5,
      "text": "Memories surrounding, as sounds sleep, and who we are.",
      "start": 34.5
    },
    {
      "end": 58,
      "text": "Which host, Earth, they party, it's only a list of the fair",
      "start": 46
    },
    {
      "end": 69.5,
      "text": "My heart stays a bit risky I wish you wasn't there",
      "start": 57.5
    },
    {
      "end": 81,
      "text": "Memories roundy As soon as sleep There who we are",
      "start": 69
    },
    {
      "end": 92.5,
      "text": "One more day, kid, until his girl",
      "start": 80.5
    },
    {
      "end": 104,
      "text": "Till more years and then I'm gone",
      "start": 92
    },
    {
      "end": 115.5,
      "text": "►",
      "start": 103.5
    },
    {
      "end": 127,
      "text": "(music)",
      "start": 115
    },
    {
      "end": 138.5,
      "text": "Some may question my wisdom To remain for the sake of a child But it's so subjective Remed of its own",
      "start": 126.5
    },
    {
      "end": 150,
      "text": "Do you explain what take a while? 'Cause February's rounding, this ain't all I'm saying",
      "start": 138
    },
    {
      "end": 161.5,
      "text": "There we are One more day",
      "start": 149.5
    },
    {
      "end": 173,
      "text": "Just 10 more years and then I'm gone",
      "start": 161
    },
    {
      "end": 184.5,
      "text": "Memories surrounding The sin of sleep There who we are",
      "start": 172.5
    },
    {
      "end": 196,
      "text": "►",
      "start": 184
    },
    {
      "end": 207.5,
      "text": "►",
      "start": 195.5
    },
    {
      "end": 219,
      "text": "Thank you.",
      "start": 207
    },
    {
      "end": 221.08,
      "text": "►",
      "start": 218.5
    }
