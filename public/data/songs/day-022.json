      "end": 8.260000228881836,
      "text": "You, oh you, yeah you",
      "start": 0
    },
    {
      "end": 13.15999984741211,
      "text": "And baby, just right now",
      "start": 8.260000228881836
    },
    {
      "end": 16.579999923706055,
      "text": "You got me walkin', baby got me walkin'",
      "start": 13.15999984741211
    },
    {
      "end": 23.399999618530273,
      "text": "Ooh, you got me walkin', baby got me walkin'",
      "start": 17.700000762939453
    },
    {
      "end": 25.959999084472656,
      "text": "Oh no",
      "start": 23.81999969482422
    },
    {
      "end": 30.18000030517578,
      "text": "I'm on a tightrope, wow, I can't know left, right",
      "start": 26.84000015258789
    },
    {
      "end": 33.900001525878906,
      "text": "Which way you want me to go",
      "start": 30.239999771118164
    },
    {
      "end": 39.040000915527344,
      "text": "Yeah, which way you want me, what",
      "start": 34.91999816894531
    },
    {
      "end": 45.68000030517578,
      "text": "Cause you got me walkin' in a single by night",
      "start": 39.040000915527344
    },
    {
      "end": 49.2599983215332,
      "text": "Can't walk it to the left, can't walk it to the right",
