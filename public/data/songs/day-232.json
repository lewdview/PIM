      "text": "I'm never gonna be the one there for you Hey girl, I'm never gonna be the one there for you",
      "start": 9.260000228881836
    },
    {
      "end": 20.600000381469727,
      "text": "Now girl, I'm never gonna be the one there for you",
      "start": 16.440000534057617
    },
    {
