    },
    {
      "end": 91.73999786376953,
      "text": "Embrace yourself with claws and grace Find your solace within",
      "start": 86.22000122070312
    },
    {
      "end": 98.73999786376953,
      "text": "Cause the sirens can't reject all of that meaning",
      "start": 92.62000274658203
    },
    {
      "end": 107.93000030517578,
      "text": "The battle within and the constant strife Afraid of losing the thread of my life",
      "start": 99.11000061035156
    },
    {
      "end": 118.2300033569336,
      "text": "Cause we all have fear within All that matters girl is how you deal with it",
      "start": 107.93000030517578
    },
    {
      "end": 132.6300048828125,
      "text": "Cause we all have fear within All that matters girl is how you deal with it",
      "start": 119.2300033569336
    },
    {
