    },
    {
      "end": 61.97999954223633,
      "text": "Now the crowds got quiet but my heart still pounds",
      "start": 59.13999938964844
    },
    {
      "end": 66.4000015258789,
      "text": "Can't hear the Oscar Stadium sound, you beat me but I found my life",
      "start": 62.040000915527344
    },
    {
      "end": 68.91999816894531,
      "text": "Guess I needed heartbreak to see the light",
      "start": 66.4000015258789
    },
    {
      "end": 71.62000274658203,
      "text": "Used to pray for love, now I pray for me",
      "start": 68.91999816894531
    },
    {
      "end": 75.5999984741211,
      "text": "Learned that freedom's the MVP, I'm calming myself like the legs do",
      "start": 71.77999877929688
    },
    {
      "end": 77.41999816894531,
      "text": "Dirt on my cleats, girl, you can't hurt me",
      "start": 75.5999984741211
    },
    {
      "end": 81.69999694824219,
      "text": "Point to the stars and I'm swinging through you",
      "start": 77.41999816894531
    },
    {
      "end": 87.12000274658203,
      "text": "Sliding in the home like I did back when I was swinging for the pins",
      "start": 81.69999694824219
    },
    {
      "end": 93.04000091552734,
      "text": "And playing in the backyard since I was a youngster, always been an all-star",
      "start": 87.12000274658203
    },
    {
      "end": 95.83999633789062,
      "text": "Before you came along, I was winning",
      "start": 93.08000183105469
    },
    {
      "end": 99.19999694824219,
      "text": "Now that you're gone, I'm going back to living again",
