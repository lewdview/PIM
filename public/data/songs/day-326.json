  "key": "C major",
  "genre": [
    "Alternative",
    "Indie"
  ],
  "difficultyLevel": 5,
  "lyrics": "I know you listen and I know you hear me through all the trees and the noise Find a way to count you in, a way to let you know I'm alright when you're gone When you're gone I lift up, up in the night We're living moments I cannot fight the darkness creeping on me I, I try, oh I try to avoid, let the thoughts just disappear but it's too hard, yeah Oh my, oh I think about you, dream about you I know you listen, it's a sin, it's a sin, no I wonder how much this is a crime, to think it's all this I wonder if I'll reach out from the edge of the abyss for one last kiss I wonder sometimes if you can see me through the fog and what's there and what's still here It's clear I know you will",
  "lyricsSegments": [
    {
      "end": 22.479999542236328,
      "text": "I know you listen and I know you hear me through all the trees and the noise",
      "start": 6.139999866485596
    },
    {
      "end": 43.900001525878906,
      "text": "Find a way to count you in, a way to let you know I'm alright when you're gone",
      "start": 25.700000762939453
    },
    {
      "end": 53.220001220703125,
      "text": "When you're gone I lift up, up in the night",
      "start": 46.060001373291016
    },
    {
      "end": 63.7400016784668,
      "text": "We're living moments I cannot fight the darkness creeping on me",
      "start": 53.439998626708984
    },
    {
      "end": 82.23999786376953,
      "text": "I, I try, oh I try to avoid, let the thoughts just disappear but it's too hard, yeah",
      "start": 63.7400016784668
    },
    {
      "end": 97.68000030517578,
      "text": "Oh my, oh I think about you, dream about you",
      "start": 82.23999786376953
    },
    {
      "end": 107.26000213623047,
      "text": "I know you listen, it's a sin, it's a sin, no",
      "start": 97.68000030517578
    },
    {
      "end": 118.77999877929688,
      "text": "I wonder how much this is a crime, to think it's all this",
      "start": 108.68000030517578
    },
    {
      "end": 129.05999755859375,
      "text": "I wonder if I'll reach out from the edge of the abyss for one last kiss",
      "start": 118.77999877929688
    },
    {
      "end": 146.8800048828125,
      "text": "I wonder sometimes if you can see me through the fog and what's there and what's still here",
      "start": 131.1199951171875
    },
    {
      "end": 154.66000366210938,
      "text": "It's clear I know you will",
      "start": 146.8800048828125
    }
  ],
  "unlock": {
    "card": "card-326",
    "fragments": 10
  }
}