      "text": "Dashboard of your only life",
      "start": 122.33999633789062
    },
    {
      "end": 128.83999633789062,
      "text": "You better pay attention to the numbers that tell you",
      "start": 126.0999984741211
    },
    {
      "end": 131.33999633789062,
      "text": "You better pay attention to the things they tell you",
      "start": 128.83999633789062
    },
    {
