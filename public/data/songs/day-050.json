    {
      "end": 199.47999572753906,
      "text": "A place to sing a song, yeah",
      "start": 196.13999938964844
    },
    {
      "end": 201.74000549316406,
      "text": "Baby, a place",
      "start": 199.47999572753906
    },
    {
      "end": 205.22000122070312,
      "text": "Where we can",
