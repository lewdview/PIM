  "key": "C# major",
  "genre": [
    "Ballad",
    "Ambient"
  ],
  "difficultyLevel": 2,
  "lyrics": "Be you, yeah, I said it once, be with respectful of you, wanna feel you, just be you, yeah, run down the line, walk with the fire, baby, walk with the fire, yeah, feel your mind, I know it gets hard to be you, I know it is all just in your view, but you gotta be true to you, and be it, be that sprinkle of light on the tired, on the beating and the down, yeah, open up your mind with pathing power, and just love it all from a smile on a towel, baby, being you is what you need to do, I'm telling you, relate your own view, be all you can be, it's life, it's fractured, view of life, ooh, I know, it gets a little rough out there in the fire, be that thing that walks through it, find another path and you're gone, gone from the dark with the light of the flames, it licks you and you feel that pain to be alive, aware, to be here in sorrow, magic and rare, you know, which way you should go, it's lift up the light and see, you're brighter than all the stars in the sky, baby, tonight when we ride to a different part of our souls, fly high, baby, know it is being you.",
  "lyricsSegments": [
    {
      "end": 25.260000228881836,
      "text": "Be you, yeah, I said it once, be with respectful of you, wanna feel you, just be you, yeah,",
      "start": 12.460000038146973
    },
    {
      "end": 36.02000045776367,
      "text": "run down the line, walk with the fire, baby, walk with the fire, yeah, feel your mind,",
      "start": 25.260000228881836
    },
    {
      "end": 51.86000061035156,
      "text": "I know it gets hard to be you, I know it is all just in your view, but you gotta be true to you,",
      "start": 36.02000045776367
    },
    {
      "end": 65.86000061035156,
      "text": "and be it, be that sprinkle of light on the tired, on the beating and the down, yeah, open up your mind with pathing power,",
      "start": 51.86000061035156
    },
    {
      "end": 80.55999755859375,
      "text": "and just love it all from a smile on a towel, baby, being you is what you need to do, I'm telling you, relate your own view,",
      "start": 66.08000183105469
    },
    {
      "end": 97.55999755859375,
      "text": "be all you can be, it's life, it's fractured, view of life, ooh, I know, it gets a little rough out there in the fire,",
      "start": 80.55999755859375
    },
    {
      "end": 110.87999725341797,
      "text": "be that thing that walks through it, find another path and you're gone, gone from the dark with the light of the flames,",
      "start": 97.55999755859375
    },
    {
      "end": 133.77999877929688,
      "text": "it licks you and you feel that pain to be alive, aware, to be here in sorrow, magic and rare, you know, which way you should go,",
      "start": 110.87999725341797
    },
    {
      "end": 160.63999938964844,
      "text": "it's lift up the light and see, you're brighter than all the stars in the sky, baby, tonight when we ride to a different part of our souls, fly high, baby, know it is being you.",
      "start": 133.77999877929688
    }
