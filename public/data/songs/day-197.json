  "key": "A# minor",
  "genre": [
    "Alternative",
    "Indie"
  ],
  "difficultyLevel": 5,
  "lyrics": "Riddle me this, riddle me that, is it hard to be nice motherfuckers yeah Riddle me this, riddle me that, is it so hard for you to not hate dude You're stuck in this riddle of it all, compaction of me yeah I can't even be me if I can't see what I should be If the foundation is cracked here internally What do we hold inside? Are we ready to find it open wide? Riddles inside Come on and open wide Riddle me this, riddle me that, are you weak? Or just a fragment of something that can't be taught? A feeling inside, do you deserve to die? Oh Riddles of the past Riddles inside All of us, reaching for the top But we fall, we just judge then When we come and get the ball, then there's no passing No wonder why we can't ever come together Oh Riddle me this, riddle me that, riddle me in the abstract of my mind But now you're fine Just a little teaching and a little communication Say what's on your mind with respect and kindness to others And find out if there's a riddle left inside, yeah",
  "lyricsSegments": [
    {
      "end": 22.239999771118164,
      "text": "Riddle me this, riddle me that, is it hard to be nice motherfuckers yeah",
      "start": 11.359999656677246
    },
    {
      "end": 39.20000076293945,
      "text": "Riddle me this, riddle me that, is it so hard for you to not hate dude",
      "start": 22.239999771118164
    },
    {
      "end": 44.34000015258789,
      "text": "You're stuck in this riddle of it all, compaction of me yeah",
      "start": 39.91999816894531
    },
    {
      "end": 47.41999816894531,
      "text": "I can't even be me if I can't see what I should be",
      "start": 44.34000015258789
    },
    {
      "end": 50.220001220703125,
      "text": "If the foundation is cracked here internally",
      "start": 47.41999816894531
    },
    {
      "end": 55.70000076293945,
      "text": "What do we hold inside?",
      "start": 50.220001220703125
    },
    {
      "end": 61.939998626708984,
      "text": "Are we ready to find it open wide?",
      "start": 55.81999969482422
    },
    {
      "end": 68.95999908447266,
      "text": "Riddles inside",
      "start": 67.23999786376953
    },
    {
      "end": 73.68000030517578,
      "text": "Come on and open wide",
      "start": 69.94000244140625
    },
    {
      "end": 79.37999725341797,
      "text": "Riddle me this, riddle me that, are you weak?",
      "start": 73.68000030517578
    },
    {
      "end": 82.72000122070312,
      "text": "Or just a fragment of something that can't be taught?",
      "start": 79.37999725341797
    },
    {
      "end": 87.68000030517578,
      "text": "A feeling inside, do you deserve to die?",
      "start": 82.9800033569336
    },
    {
      "end": 90.26000213623047,
      "text": "Oh",
      "start": 89.95999908447266
    },
    {
      "end": 98.86000061035156,
      "text": "Riddles of the past",
      "start": 95.72000122070312
    },
    {
      "end": 101.55999755859375,
      "text": "Riddles inside",
      "start": 100.12000274658203
    },
    {
      "end": 104.63999938964844,
      "text": "All of us, reaching for the top",
      "start": 101.94000244140625
    },
    {
      "end": 108.5199966430664,
      "text": "But we fall, we just judge then",
      "start": 104.63999938964844
    },
    {
      "end": 111.27999877929688,
      "text": "When we come and get the ball, then there's no passing",
      "start": 108.5199966430664
    },
    {
      "end": 115.5199966430664,
      "text": "No wonder why we can't ever come together",
      "start": 111.27999877929688
    },
    {
      "end": 117.36000061035156,
      "text": "Oh",
      "start": 116.66000366210938
    },
    {
      "end": 130.32000732421875,
      "text": "Riddle me this, riddle me that, riddle me in the abstract of my mind",
      "start": 117.36000061035156
    },
    {
      "end": 133.8000030517578,
      "text": "But now you're fine",
      "start": 131.24000549316406
    },
    {
      "end": 138.44000244140625,
      "text": "Just a little teaching and a little communication",
      "start": 133.8000030517578
    },
    {
      "end": 143.39999389648438,
      "text": "Say what's on your mind with respect and kindness to others",
      "start": 139.75999450683594
    },
    {
      "end": 147.1999969482422,
      "text": "And find out if there's a riddle left inside, yeah",
      "start": 143.39999389648438
    }
  ],
  "unlock": {
    "card": "card-197",
    "fragments": 10
  }
}