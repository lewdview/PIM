    {
      "end": 134.8000030517578,
      "text": "As each mile marker passes",
      "start": 131.8000030517578
    },
    {
      "end": 138.60000610351562,
      "text": "Like pages in a book of chapter closed",
      "start": 134.8000030517578
    },
    {
