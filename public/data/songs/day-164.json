    },
    {
      "end": 37.540000915527344,
      "text": "My last breath, my last time",
      "start": 30.34000015258789
    },
    {
      "end": 47.41999816894531,
      "text": "Down to my last breath",
      "start": 40.68000030517578
    },
    {
      "end": 53.7400016784668,
      "text": "Oh, I'm down on my luck at last",
      "start": 47.41999816894531
    },
    {
      "end": 62.939998626708984,
      "text": "I'm down to let you one last breath",
      "start": 54.7400016784668
    },
    {
      "end": 71.5,
      "text": "Hate me now, yeah, hate me for the rest of your disaster of a life",
      "start": 62.939998626708984
    },
    {
      "end": 76.95999908447266,
      "text": "Hate me for the things that I did to you",
      "start": 71.5
    },
    {
      "end": 84.73999786376953,
      "text": "If it makes it easier to see me fall",
      "start": 76.95999908447266
    },
    {
      "end": 91.63999938964844,
      "text": "Never would've treated you the way you made me out",
      "start": 84.73999786376953
    },
    {
      "end": 102.26000213623047,
      "text": "Yeah, I'm down, down, down to one last breath",
      "start": 94.12000274658203
    },
    {
      "end": 109.23999786376953,
      "text": "I'm down, down, down to one last breath",
      "start": 103.81999969482422
    },
    {
      "end": 117.58000183105469,
      "text": "One last thought, one last life, one last moment to tell you I'll never ever be near again",
      "start": 109.23999786376953
    },
    {
      "end": 124.4800033569336,
      "text": "I'm down to this last thought of you and all I'll ever be",
      "start": 117.58000183105469
    },
    {
      "end": 128.33999633789062,
      "text": "Oh, oh, oh, oh, oh, oh, oh",
      "start": 124.4800033569336
    },
    {
      "end": 137.16000366210938,
      "text": "Is it gonna get worse when you try to ignore the things that got us here in the first place",
      "start": 129.6199951171875
    },
    {
      "end": 142.82000732421875,
      "text": "And you look at me like a waste of space",
      "start": 137.16000366210938
    },
    {
      "end": 147.94000244140625,
      "text": "I'm just wasting your space and time",
      "start": 143.52000427246094
    },
    {
      "end": 155.36000061035156,
      "text": "All the packages and all the lies and everything I read to you to make you think you wanted me as yours",
      "start": 147.94000244140625
    },
    {
      "end": 162.94000244140625,
      "text": "Well, guess what, I'm down, down, down, down to one last breath, one last breath",
      "start": 155.36000061035156
    },
    {
      "end": 170.13999938964844,
      "text": "Yeah, I'm just down, down, down, down to one last breath of you",
      "start": 163.4600067138672
    },
    {
      "end": 174.72000122070312,
      "text": "One last thought, I'm down, down, down, down to one",
      "start": 170.13999938964844
    },
    {
      "end": 179.8000030517578,
      "text": "Once again, I know I'm forever as I am",
      "start": 175.32000732421875
    },
    {
      "end": 183.05999755859375,
      "text": "I'll see you again, y'all",
      "start": 179.8800048828125
    },
    {
      "end": 188.4199981689453,
      "text": "Different perspective of life and death, reincarnation, why you fight me now?",
      "start": 183.05999755859375
    },
    {
      "end": 192.5,
      "text": "I'm down to one last breath",
      "start": 189.0399932861328
    },
    {
      "end": 196.1999969482422,
      "text": "I'm down to one last hell",
      "start": 193.05999755859375
    },
    {
      "end": 202.1999969482422,
      "text": "One last breath of me in my mental jail, yeah",
      "start": 196.1999969482422
    },
    {
      "end": 209.82000732421875,
      "text": "I'm down, down, down to one last breath for me",
      "start": 202.83999633789062
    },
    {
      "end": 218,
      "text": "Yeah, I'm down, down to one last breath",
      "start": 209.82000732421875
    },
    {
      "end": 222.44000244140625,
      "text": "Oh, baby, yeah, there's no way you can fix us here",
      "start": 218
    },
    {
      "end": 227.36000061035156,
      "text": "We're broken and gone and doomed, and gone and doomed, yeah",
      "start": 222.44000244140625
    },
    {
      "end": 232.82000732421875,
      "text": "There's no way you can fix us, baby, we're just gone and doomed",
      "start": 227.60000610351562
    },
    {
      "end": 241.05999755859375,
      "text": "Our life has become a toxic non-healing mess of fabrication of lies, lies, lies",
      "start": 232.82000732421875
    },
    {
      "end": 245.6199951171875,
      "text": "As you go give up somewhere else and I cry and die",
      "start": 241.05999755859375
    },
    {
      "end": 249.94000244140625,
      "text": "Cause I'm down, down, down, down to my last breath for you",
      "start": 245.6199951171875
    }
