      "start": 25.040000915527344
    },
    {
      "end": 31.18000030517578,
      "text": "I ain't trying to live forever",
      "start": 28.700000762939453
    },
    {
      "end": 33.70000076293945,
      "text": "Forever, forever, forever, forever, forever",
      "start": 31.18000030517578
    },
    {
      "end": 37.70000076293945,
      "text": "Creativity to teach you",
      "start": 35.599998474121094
    },
    {
      "end": 39.70000076293945,
      "text": "Live forever, forever in you",
      "start": 37.70000076293945
    },
    {
      "end": 43.84000015258789,
      "text": "M-S-Q-T-X",
      "start": 41
    },
    {
      "end": 46.119998931884766,
      "text": "Forever, forever in you",
      "start": 43.84000015258789
    },
    {
      "end": 49.52000045776367,
      "text": "All praise is due to the Most High",
      "start": 46.959999084472656
    },
    {
      "end": 52.58000183105469,
      "text": "And everything preceded by my third eye",
      "start": 49.619998931884766
    },
    {
      "end": 55.119998931884766,
      "text": "I was raised a Jehovah's Witness",
      "start": 52.880001068115234
    },
    {
      "end": 56.79999923706055,
      "text": "Found quickly nothing was in it",
      "start": 55.119998931884766
    },
    {
      "end": 59.619998931884766,
      "text": "Fuck that organized religion, I'm a soldier with a vision",
      "start": 56.79999923706055
    },
    {
      "end": 61.15999984741211,
      "text": "Addiction was not an option",
      "start": 59.65999984741211
    },
    {
      "end": 64.22000122070312,
      "text": "Give me a fighting chance, I'll fight any nigga and drop him",
      "start": 61.15999984741211
    },
    {
      "end": 67.44000244140625,
      "text": "Yeah, I see motherfuckers get mutilated",
      "start": 64.77999877929688
    },
    {
      "end": 70.80000305175781,
      "text": "Separated, disintegrated, I barely made it",
      "start": 68.5
    },
    {
      "end": 73.55999755859375,
      "text": "Yeah, you motherfuckers don't want none",
      "start": 71.05999755859375
    },
    {
      "end": 76.69999694824219,
      "text": "Gatlin, I named my own son after a huge gun",
      "start": 73.5
    },
    {
      "end": 79.26000213623047,
      "text": "Yeah, that means I'm really with the bullshit",
      "start": 77.0999984741211
    },
    {
      "end": 82.36000061035156,
      "text": "And I don't waste no time, my time is precious in the pulpit",
      "start": 79.26000213623047
    },
    {
      "end": 83.44000244140625,
      "text": "So live forever",
      "start": 82.36000061035156
    },
    {
      "end": 85.05999755859375,
      "text": "Are you gonna live forever?",
      "start": 83.44000244140625
    },
    {
      "end": 88.80000305175781,
      "text": "Forever, forever, forever, forever",
      "start": 85.41999816894531
    },
    {
      "end": 91.22000122070312,
      "text": "Are you gonna be forever?",
      "start": 88.80000305175781
    },
    {
      "end": 95.0199966430664,
      "text": "Forever, forever, forever, forever",
      "start": 92.13999938964844
    },
    {
      "end": 100.05999755859375,
      "text": "Sing the songs, sing the music of our times",
      "start": 95.0199966430664
    },
    {
      "end": 104.23999786376953,
      "text": "Live forever, forever, forever, forever",
      "start": 100.08000183105469
    },
    {
      "end": 106.95999908447266,
      "text": "Are you gonna go down that line",
      "start": 104.23999786376953
    },
    {
      "end": 112.44000244140625,
      "text": "Live forever, forever, forever, forever",
      "start": 106.95999908447266
    },
    {
      "end": 114.27999877929688,
      "text": "Come on, one more time",
      "start": 112.44000244140625
    },
    {
      "end": 118.95999908447266,
      "text": "Forever, forever, forever, forever",
      "start": 116.27999877929688
    },
    {
      "end": 121.45999908447266,
      "text": "Yeah, the X-Man with a ex-wife",
      "start": 118.95999908447266
    },
    {
      "end": 124.41999816894531,
      "text": "So many demons you would think I was the Antichrist",
      "start": 121.45999908447266
    },
    {
      "end": 126.95999908447266,
      "text": "Yeah, talkin' down on your websites",
      "start": 125.0199966430664
    },
    {
      "end": 130.55999755859375,
      "text": "Bitch, I ain't on the web, I'm in real life",
      "start": 127.91999816894531
    },
    {
      "end": 133.27999877929688,
      "text": "Yeah, sock a nigga in his forehead",
      "start": 131.33999633789062
    },
    {
      "end": 136.3800048828125,
      "text": "Put somethin' on his mind, cross the line, nigga, go ahead",
      "start": 133.27999877929688
    },
    {
      "end": 139.6199951171875,
      "text": "And that shit don't make me tough, I'm tough",
      "start": 137.05999755859375
    },
    {
      "end": 142.5399932861328,
      "text": "Cause I chose to live after decades of fuckin' up",
      "start": 139.6199951171875
    },
    {
      "end": 144.77999877929688,
      "text": "The D.O.C., my favorite rapper",
      "start": 142.8000030517578
    },
    {
      "end": 146.47999572753906,
      "text": "Is there really an afterlife?",
      "start": 144.77999877929688
    },
    {
      "end": 148.3800048828125,
      "text": "And if so, can I smoke a backwood?",
      "start": 146.5800018310547
    },
    {
      "end": 151.55999755859375,
      "text": "Yeah, I gave my life to artistic endeavors",
      "start": 148.86000061035156
    },
    {
      "end": 154.5,
      "text": "And took the measure to assure I would be here forever",
      "start": 151.55999755859375
    },
    {
      "end": 155.60000610351562,
      "text": "Are you gonna live forever?",
      "start": 154.5
    },
    {
      "end": 158.22000122070312,
      "text": "Forever, forever, forever, forever",
      "start": 156.52000427246094
    },
    {
      "end": 162.3000030517578,
      "text": "Are you gonna sing your song?",
      "start": 159.97999572753906
    },
    {
      "end": 166.77999877929688,
      "text": "Forever, forever, forever, forever, forever",
      "start": 162.3000030517578
    },
    {
      "end": 169.86000061035156,
      "text": "Put your lives down in the pavement",
      "start": 166.77999877929688
    },
    {
      "end": 172.8800048828125,
      "text": "Put your stance on the wall",
      "start": 169.86000061035156
    },
    {
      "end": 175.74000549316406,
      "text": "Tell us your feelings about you",
      "start": 172.8800048828125
    },
    {
      "end": 178.3000030517578,
      "text": "And stand for somethin' now",
      "start": 175.74000549316406
    },
    {
      "end": 182.27999877929688,
      "text": "Through song and music you can uplift your people",
      "start": 178.94000244140625
    },
    {
      "end": 184.3000030517578,
      "text": "Stand tall on your own",
      "start": 182.27999877929688
    },
    {
      "end": 187.3000030517578,
      "text": "Through these rhymes and through these songs",
      "start": 185.05999755859375
    },
    {
      "end": 190.32000732421875,
      "text": "We're gonna live forever",
      "start": 188
    },
    {
      "end": 193.32000732421875,
      "text": "I come around to live forever",
      "start": 190.32000732421875
    },
    {
      "end": 197.3800048828125,
      "text": "Forever, forever, forever, forever",
      "start": 193.8800048828125
    },
    {
      "end": 200.74000549316406,
      "text": "Are you gonna sing with us and live forever?",
      "start": 197.3800048828125
    },
    {
      "end": 204.52000427246094,
      "text": "Forever, forever, forever, forever, forever",
      "start": 200.82000732421875
    },
    {
      "end": 205.32000732421875,
      "text": "And you",
      "start": 204.52000427246094
    },
    {
      "end": 208.0800018310547,
      "text": "Do-do-do-do-do-do",
      "start": 205.86000061035156
    },
    {
      "end": 211.24000549316406,
      "text": "X to the Z and a scribe to V",
      "start": 208.0800018310547
    }
