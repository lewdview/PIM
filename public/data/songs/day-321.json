    },
    {
      "end": 84.87999725341797,
      "text": "Don't bring me down",
      "start": 80.33999633789062
    },
    {
      "end": 96,
      "text": "Every day and night",
      "start": 92.86000061035156
    },
    {
      "end": 97.91999816894531,
      "text": "I've seen many types of knots",
